# Base de datos (docker-compose expone Postgres en localhost:5432 para desarrollo local sin Docker)
DATABASE_URL=postgresql://exam_app:exam_app_password@localhost:5433/exam_system

# Autenticación docente
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
COOKIE_SECURE=false

# Usuario docente inicial (creado por prisma/seed.ts)
SEED_TEACHER_EMAIL=docente@example.com
SEED_TEACHER_NAME=Docente Administrador
SEED_TEACHER_PASSWORD=cambia-esta-clave

# Evaluación con IA (opcional, sólo si allowAiCodeEvaluation está habilitado en un examen)
AI_API_KEY=sk-ant-tu-api-key-aqui
AI_MODEL=claude-sonnet-5

# Red / proxies
# Poner en "true" sólo si la app corre detrás de un proxy confiable (nginx, load balancer)
# que setea X-Forwarded-For correctamente. En caso contrario se usa la IP del socket.
TRUST_PROXY=false

NEXT_PUBLIC_APP_URL=http://localhost:3000

NODE_ENV=development
